# ==============================================================================
# WhatTools Environment Variables
# Copy to .env and fill in values
# ==============================================================================

# ------------------------------------------------------------------------------
# Flask
# ------------------------------------------------------------------------------
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://whattools:whattools@localhost:5432/whattools
POSTGRES_USER=whattools
POSTGRES_PASSWORD=whattools
POSTGRES_DB=whattools

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ------------------------------------------------------------------------------
# JWT Auth
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# ------------------------------------------------------------------------------
# Email (SendGrid or Resend)
# ------------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@whattools.trector.com

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=120/minute

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://whattools.trector.com

# ------------------------------------------------------------------------------
# Service URLs (internal, used by gateway)
# ------------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth:5001
INVENTORY_SERVICE_URL=http://inventory:5002
GATEWAY_PORT=5000
AUTH_PORT=5001
INVENTORY_PORT=5002

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=DEBUG

# ------------------------------------------------------------------------------
# Gateway Proxy
# ------------------------------------------------------------------------------
PROXY_TIMEOUT=30
HEALTH_CHECK_TIMEOUT=5
